# ============================================================
# StartupPilot AI — Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp backend/.env.example backend/.env
# ============================================================

# ── Supabase (REQUIRED) ──────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json

# ── AI Providers (at least ONE is required for AI analysis) ──
# Google Gemini: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# OpenAI (optional fallback): https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic Claude (optional fallback): https://console.anthropic.com
ANTHROPIC_API_KEY=

# Groq (optional fallback — free tier available): https://console.groq.com
GROQ_API_KEY=

# Together AI (optional fallback): https://www.together.ai
TOGETHER_API_KEY=

# ── AI Provider Configuration ────────────────────────────────
# Which provider to use first ("gemini", "openai", "claude", "groq", "together")
PRIMARY_AI_PROVIDER=gemini
SECONDARY_AI_PROVIDER=openai
# Comma-separated fallback order (after primary/secondary)
AI_FALLBACK_ORDER=groq,claude,together

# ── AI Models (optional — defaults shown) ────────────────────
GEMINI_MODEL=gemini-flash-latest
OPENAI_MODEL=gpt-4o-mini
CLAUDE_MODEL=claude-opus-4-5
GROQ_MODEL=llama-3.3-70b-versatile
TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

# ── App Settings (optional) ──────────────────────────────────
APP_ENV=development
DEBUG=true
# Must be 32+ characters for production
SECRET_KEY=change-this-secret-key-in-production-minimum-32-characters

# ── Frontend URL (for CORS) ───────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
FRONTEND_URL=http://localhost:5173

# ── File Storage ─────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
