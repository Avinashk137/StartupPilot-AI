{
  "name": "startuppilot-ai",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "setup": "node scripts/setup.js",
    "dev": "node scripts/start-dev.js",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "node -e \"const p=process.platform==='win32'?'backend/venv/Scripts/python':'backend/venv/bin/python'; require('child_process').spawn(p, ['-m', 'uvicorn', 'backend.main:app', '--reload', '--host', '127.0.0.1', '--port', '8000'], {cwd: __dirname, stdio: 'inherit', shell: false})\"",
    "install:all": "node scripts/setup.js"
  },
  "dependencies": {
    "@supabase/server": "^1.1.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
